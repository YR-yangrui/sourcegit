<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:c="using:SourceGit.Converters"
             xmlns:m="using:SourceGit.Models"
             xmlns:vm="using:SourceGit.ViewModels"
             xmlns:v="using:SourceGit.Views"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="640"
             x:Class="SourceGit.Views.StructuredDiffView"
             x:DataType="vm:StructuredDiffContext">
  <UserControl.Styles>
    <Style Selector="Border.state">
      <Setter Property="Width" Value="4"/>
      <Setter Property="Margin" Value="0,0,6,0"/>
      <Setter Property="CornerRadius" Value="2"/>
      <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="Border.state.added">
      <Setter Property="Background" Value="#33AA44"/>
    </Style>

    <Style Selector="Border.state.deleted">
      <Setter Property="Background" Value="#CC3333"/>
    </Style>

    <Style Selector="Border.state.modified">
      <Setter Property="Background" Value="#D8A400"/>
    </Style>

    <Style Selector="Border.prefab_stat">
      <Setter Property="MinWidth" Value="94"/>
      <Setter Property="Padding" Value="10,6"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border2}"/>
      <Setter Property="Background" Value="{DynamicResource Brush.Window}"/>
    </Style>

    <Style Selector="TextBlock.prefab_stat_value">
      <Setter Property="FontSize" Value="18"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="TextBlock.prefab_stat_label">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Foreground" Value="{DynamicResource Brush.FG2}"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*" Background="{DynamicResource Brush.Contents}">
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
      <TextBlock Grid.Column="0"
                 Margin="8,6"
                 Foreground="{DynamicResource Brush.FG2}"
                 FontSize="12"
                 Text="{Binding Diff.Summary}"/>
      <Button Grid.Column="1"
              Classes="flat"
              Margin="8,4"
              Content="{Binding TableFilterButtonText}"
              IsVisible="{Binding IsTable}"
              Click="OnToggleTableFilter"/>
    </Grid>

    <TabControl Grid.Row="1" ItemsSource="{Binding Diff.Sheets}" IsVisible="{Binding IsTable}">
      <TabControl.ItemTemplate>
        <DataTemplate DataType="m:StructuredDiffSheet">
          <TextBlock Text="{Binding Header}"/>
        </DataTemplate>
      </TabControl.ItemTemplate>

      <TabControl.ContentTemplate>
        <DataTemplate DataType="m:StructuredDiffSheet">
          <v:StructuredDiffSheetView/>
        </DataTemplate>
      </TabControl.ContentTemplate>
    </TabControl>

    <Grid Grid.Row="1" RowDefinitions="Auto,*" IsVisible="{Binding IsHierarchy}">
      <Border Grid.Row="0"
              BorderThickness="0,1,0,1"
              BorderBrush="{DynamicResource Brush.Border2}"
              Background="{DynamicResource Brush.Window}">
        <Grid ColumnDefinitions="*,Auto" Margin="10,8">
          <StackPanel Grid.Column="0" Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Classes="prefab_stat">
                <StackPanel>
                  <TextBlock Classes="prefab_stat_value" Foreground="#33AA44" Text="{Binding PrefabAddedNodes}"/>
                  <TextBlock Classes="prefab_stat_label" Text="新增节点"/>
                </StackPanel>
              </Border>
              <Border Classes="prefab_stat">
                <StackPanel>
                  <TextBlock Classes="prefab_stat_value" Foreground="#CC3333" Text="{Binding PrefabDeletedNodes}"/>
                  <TextBlock Classes="prefab_stat_label" Text="删除节点"/>
                </StackPanel>
              </Border>
              <Border Classes="prefab_stat">
                <StackPanel>
                  <TextBlock Classes="prefab_stat_value" Foreground="#D8A400" Text="{Binding PrefabModifiedNodes}"/>
                  <TextBlock Classes="prefab_stat_label" Text="修改节点"/>
                </StackPanel>
              </Border>
              <Border Classes="prefab_stat">
                <StackPanel>
                  <TextBlock Classes="prefab_stat_value" Text="{Binding PrefabChangedProperties}"/>
                  <TextBlock Classes="prefab_stat_label" Text="属性改动"/>
                </StackPanel>
              </Border>
            </StackPanel>
            <TextBlock Foreground="{DynamicResource Brush.FG2}"
                       FontSize="11"
                       Text="{Binding PrefabSummaryText}"/>
          </StackPanel>

          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Spacing="8">
            <Button Classes="flat"
                    Content="Hierarchy"
                    Click="OnShowPrefabHierarchy"/>
            <Button Classes="flat"
                    Content="格式化Diff"
                    Click="OnShowFormattedPrefabDiff"/>
            <Button Classes="flat"
                    Content="原始Diff"
                    IsEnabled="{Binding HasRawPrefabDiff}"
                    Click="OnShowRawPrefabDiff"/>
            <Button Classes="flat"
                    Content="{Binding PrefabFilterButtonText}"
                    Click="OnTogglePrefabFilter"/>
          </StackPanel>
        </Grid>
      </Border>

      <Grid Grid.Row="1" ColumnDefinitions="340,*" IsVisible="{Binding IsShowingPrefabHierarchy}">
        <Border Grid.Column="0" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource Brush.Border2}">
          <TreeView ItemsSource="{Binding VisiblePrefabNodes}"
                    SelectedItem="{Binding SelectedNode, Mode=TwoWay}"
                    Background="Transparent"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                    ScrollViewer.VerticalScrollBarVisibility="Auto">
            <TreeView.Styles>
              <Style Selector="TreeViewItem">
                <Setter Property="MinHeight" Value="26"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="IsExpanded" Value="True"/>
              </Style>
            </TreeView.Styles>

            <TreeView.DataTemplates>
              <TreeDataTemplate DataType="m:StructuredDiffNode" ItemsSource="{Binding Children}">
                <Grid ColumnDefinitions="Auto,*,Auto" Height="26">
                  <Border Grid.Column="0"
                          Classes="state"
                          Classes.added="{Binding IsAdded}"
                          Classes.deleted="{Binding IsDeleted}"
                          Classes.modified="{Binding IsModified}"/>
                  <TextBlock Grid.Column="1"
                             Text="{Binding Name}"
                             TextTrimming="CharacterEllipsis"/>
                  <TextBlock Grid.Column="2"
                             Margin="8,0,6,0"
                             FontSize="10"
                             Foreground="{DynamicResource Brush.FG2}"
                             Text="{Binding ChangeLabel}"/>
                </Grid>
              </TreeDataTemplate>
            </TreeView.DataTemplates>
          </TreeView>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="Auto,*">
          <Border Grid.Row="0"
                  Margin="10,10,10,8"
                  Padding="10,8"
                  CornerRadius="6"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource Brush.Border2}"
                  Background="{DynamicResource Brush.Window}">
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding SelectedNode.Path}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
              <TextBlock Text="{Binding SelectedNode.Summary}" FontSize="11" Foreground="{DynamicResource Brush.FG2}"/>
            </StackPanel>
          </Border>

          <ScrollViewer Grid.Row="1" Margin="10,0,10,10" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding SelectedNode.PropertyGroups}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="m:StructuredPropertyGroup">
                  <StackPanel Margin="0,0,0,8">
                    <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  Padding="0"
                                  BorderThickness="1"
                                  BorderBrush="{DynamicResource Brush.Border2}"
                                  Background="{DynamicResource Brush.Window}">
                      <Grid ColumnDefinitions="4,Auto,*" Margin="0,0,8,0">
                        <Border Grid.Column="0"
                                Classes="state"
                                Margin="0"
                                CornerRadius="0"
                                Classes.added="{Binding IsAdded}"
                                Classes.deleted="{Binding IsDeleted}"
                                Classes.modified="{Binding IsModified}"/>
                        <TextBlock Grid.Column="1"
                                   Margin="8,6,0,6"
                                   Width="16"
                                   Text="{Binding IsExpanded, Converter={x:Static c:BoolConverters.IsExpandedToTriangle}}"/>
                        <TextBlock Grid.Column="2"
                                   Margin="0,6,0,6"
                                   Text="{Binding Header}"
                                   TextTrimming="CharacterEllipsis"/>
                      </Grid>
                    </ToggleButton>

                    <Grid RowDefinitions="Auto,*" IsVisible="{Binding IsExpanded}">
                      <Border Grid.Row="0"
                              BorderThickness="1"
                              BorderBrush="{DynamicResource Brush.Border2}"
                              Background="{DynamicResource Brush.Window}">
                        <Grid ColumnDefinitions="4,220,*,*">
                          <TextBlock Grid.Column="1" Margin="18,6,8,6" Text="属性" FontWeight="SemiBold"/>
                          <TextBlock Grid.Column="2" Margin="8,6" Text="旧值" FontWeight="SemiBold"/>
                          <TextBlock Grid.Column="3" Margin="8,6" Text="新值" FontWeight="SemiBold"/>
                        </Grid>
                      </Border>

                      <ItemsControl Grid.Row="1" ItemsSource="{Binding Changes}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate DataType="m:StructuredPropertyChange">
                            <Border BorderThickness="1,0,1,1"
                                    BorderBrush="{DynamicResource Brush.Border2}"
                                    Background="{DynamicResource Brush.Window}">
                              <Grid ColumnDefinitions="4,220,*,*">
                                <Border Grid.Column="0"
                                        Classes="state"
                                        Margin="0"
                                        CornerRadius="0"
                                        Classes.added="{Binding IsAdded}"
                                        Classes.deleted="{Binding IsDeleted}"
                                        Classes.modified="{Binding IsModified}"/>
                                <TextBlock Grid.Column="1"
                                           Margin="18,6,8,6"
                                           Text="{Binding DisplayKey}"
                                           FontFamily="{DynamicResource Fonts.Monospace}"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="2"
                                           Margin="8,6"
                                           Text="{Binding OldValue}"
                                           FontFamily="{DynamicResource Fonts.Monospace}"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="3"
                                           Margin="8,6"
                                           Text="{Binding NewValue}"
                                           FontFamily="{DynamicResource Fonts.Monospace}"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"/>
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </Grid>
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Grid>

      <ContentControl Grid.Row="1" Content="{Binding FormattedPrefabDiff}" IsVisible="{Binding IsShowingFormattedPrefabDiff}">
        <ContentControl.DataTemplates>
          <DataTemplate DataType="vm:TextDiffContext">
            <v:TextDiffView SelectedChunk="{Binding SelectedChunk, Mode=OneWay}"/>
          </DataTemplate>
        </ContentControl.DataTemplates>
      </ContentControl>

      <ContentControl Grid.Row="1" Content="{Binding RawPrefabDiff}" IsVisible="{Binding IsShowingRawPrefabDiff}">
        <ContentControl.DataTemplates>
          <DataTemplate DataType="vm:TextDiffContext">
            <v:TextDiffView SelectedChunk="{Binding SelectedChunk, Mode=OneWay}"/>
          </DataTemplate>
        </ContentControl.DataTemplates>
      </ContentControl>

    </Grid>
  </Grid>
</UserControl>
